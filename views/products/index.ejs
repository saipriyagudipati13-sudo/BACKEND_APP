<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h2>Products Admin Page</h2>
    <ol>
        <% products.forEach(product => { %>
            <li>
                <%= product.name %>-
                    <%=product.desc %>-
                        <%= product.price %>-
                            <%= product.imageUrl %>
            </li>
            <% }) %>
    </ol>
</body>

</html>